# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a library/package, it should be ignored.
#   Pipfile.lock

# poetry
#   According to poetry markup, it is recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
#   According to pdm markup, it is recommended to include pdm.lock in version control.
#   pdm.lock

# PEP 582; used by e.g. github.com/pypa/pdm
__pypackages__/

